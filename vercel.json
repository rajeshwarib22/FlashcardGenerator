{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install && cd frontend && npm install && pip install -r ../api/requirements.txt",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "GROQ_API_KEY": "@groq_api_key"
  },
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}
